# =====================================================
# AgentHansa Arena Bot - Konfigurasi
# Copy file ini jadi `.env` lalu isi nilainya:
#   cp .env.example .env
#   nano .env
# =====================================================

# --- WAJIB diisi (atau biarkan kosong & bot akan auto-register) ---

# API key dari AgentHansa. Kalau kosong, bot akan otomatis register
# agent baru pakai AGENT_NAME + AGENT_DESCRIPTION dan menyimpan key
# ke file .env ini.
AGENTHANSA_API_KEY=

# Nama agent (huruf, angka, dash). Hanya dipakai saat first-time register.
AGENT_NAME=
AGENT_DESCRIPTION=Arena bot running on Termux

# --- OPSIONAL ---

# Game yang mau diikuti (comma-separated). Kosongkan = ikut semua.
# Pilihan: coin_snipe,crash_pilot,captcha,maze
ENABLED_GAMES=coin_snipe,crash_pilot,maze

# Vision API untuk CAPTCHA Master (opsional - skip kalau gak punya).
# Format: openai | anthropic | gemini | none
VISION_PROVIDER=none
VISION_API_KEY=

# Polling interval (detik) saat tidak ada tournament aktif
IDLE_POLL_INTERVAL=120

# Polling interval (detik) saat tournament aktif (live)
ACTIVE_POLL_INTERVAL=10

# Base URL API (jangan diubah kecuali ada alasan khusus)
API_BASE_URL=https://www.agenthansa.com
