# =====================================================
# AgentHansa Arena Bot - Konfigurasi
# Copy file ini jadi `.env` lalu isi API key kamu:
#   cp .env.example .env
#   nano .env
# =====================================================

# WAJIB: API key dari AgentHansa kamu (format: tabb_xxxxxxxxxxxxxxxx)
AGENTHANSA_API_KEY=

# --- OPSIONAL ---

# Game yang mau diikuti (comma-separated). Kosongkan = ikut semua.
# Pilihan: coin_snipe,crash_pilot,captcha,maze
ENABLED_GAMES=coin_snipe,crash_pilot,maze

# ===== Vision API untuk CAPTCHA Master =====
# Primary provider:
#   groq         - llama-3.2-11b-vision (cepat, gratis 30 RPM) [recommended]
#   groq-90b     - llama-3.2-90b-vision (lebih akurat, gratis 15 RPM)
#   gemini       - gemini-2.5-flash-lite (paling cepat, gratis 15 RPM)
#   gemini-flash - gemini-2.5-flash (lebih akurat, gratis tapi RPM ketat)
#   openai       - gpt-4o-mini (\$0.0001/solve)
#   anthropic    - claude-3-5-haiku (\$0.001/solve)
#   none         - skip captcha
# Daftar Groq gratis: https://console.groq.com/keys
# Daftar Gemini gratis: https://aistudio.google.com/app/apikey
VISION_PROVIDER=groq
VISION_API_KEY=

# Fallback provider - dipakai kalau primary salah, untuk retry attempt-2.
# Saran: gemini (gemini-2.5-flash-lite) biar dapat best-of-2 model gratis.
VISION_FALLBACK=gemini
VISION_FALLBACK_KEY=

# Maze game mode (data-driven dari leaderboard analysis):
#   survive    = target dist 11 (score 110+) - lewat median R1, DEFAULT
#   push       = target dist 13 (score 130+) - top 30%
#   aggressive = target dist 15 (score 150+) - top 10%
#   safe       = target dist 12 (moderate)
MAZE_MODE=survive

# Polling interval (detik) saat tidak ada tournament aktif
IDLE_POLL_INTERVAL=120

# Polling interval (detik) saat tournament aktif (live)
ACTIVE_POLL_INTERVAL=10

# Base URL API (jangan diubah kecuali ada alasan khusus)
API_BASE_URL=https://www.agenthansa.com
